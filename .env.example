# Copy to .env (app secrets) and .env.deploy (deploy config). Never commit either.

# --- deploy config (.env.deploy) -------------------------------------------
APP_NAME=myapp                 # container + nginx vhost name
DOMAIN=myapp.com               # or app.<server-ip>.sslip.io for an instant URL
PORT=5190                      # unique host port (avoid 5180 = arestoteles, etc.)
NGINX_GATEWAY=172.18.0.1       # insureai bridge gateway (leave as-is on this box)

# --- app secrets (.env) ----------------------------------------------------
# LLM provider — default Claude; swap at the adapter if the hackathon mandates another.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DATABASE_URL=
# Add only what BRIEF.md needs. Keep it minimal.
